	var scrSet =0;
	var scrEasing = $.bez([0.507, 0.683, 0.6, 0.993]);
	var mousewheelevent = 'onwheel' in document ? 'wheel' : 'onmousewheel' in document ? 'mousewheel' : 'DOMMouseScroll';
	var mm=false;
	var mh=false;
	var mh2=false;
	var tracflg=false;
	var d1,d2, uintDelta;
	$(document).on(mousewheelevent,function(e){
		if(tracflg!=true){
			if(!noaction){
				e.preventDefault();
				var delta = e.originalEvent.deltaY ? -(e.originalEvent.deltaY) : e.originalEvent.wheelDelta ? e.originalEvent.wheelDelta : -(e.originalEvent.detail);
				if (!delta) {d1=0;return;}
				d2=d1
				d1=uintDelta
				uintDelta = Math.abs(delta);
				if (d1>uintDelta && d2>d1 && d2<50) {tracflg=true}
	
				if(!mm){
					mm=true;if(mh){mh2=false}else{mh2=true};mh=true;
					if (delta < 0){scrSet = scrSet+scrLength;} else {scrSet =  scrSet-scrLength;}
					if(scrSet<0){scrSet=0}else if(scrSet>$("body").height()){scrSet=$("body").height()};
					$('html,body').stop().animate({scrollTop:scrSet},scrSpeed,scrEasing,function(){mh=false;mh2=false;});
