// JavaScript Document
$(function(){
	
	var MODE = {PC:'PC',TAB:'TAB',SP:'SP'};
	var WIDTH = {'PC':1000,'TAB':770,'SP':0};
	var HEIGHT_LINE_TARGET = [
		'#topics-inner>.contents>.list-3col>li>.wrap',
		'#game>.list-3col>li>.wrap',
		'#service>.list-4col>li',
		'#game>.list-4col>li',
		'#menu-list>.list-5col>li',
		'#picup>.list-5col>li'
	];
	var JSON_PATH = '';
	var SELECTIVIZR_PATH = '/common/js/selectivizr.js';
	var JS_MOVIE_BTN = 'js-movie-btn';
	var JS_MOVIE_WRAPPER = 'js-movie-wrapper';
	var JS_MOVIE_CONTENTS = 'js-movie-contents';
	var JS_MOVIE_CONTENTS_INNR = 'js-movie-contents-innr';
	var JS_MOVIE_CLOSE = 'js-movie-close';
	
	//ウィンドウモード
	var mode = '';
	
	//ヘッダーアンカー表示可否
	var isAnchor = false;
	
	//古いIEかどうか
	var isOldIE = false;
	
	//PS3ブラウザかどうか
	var isPS3 = false;
	
	//PSVitaブラウザかどうか
	var isVita = false;
	
	//json配列
	var jsonObj = new Array();
	
	//初期設定
	init();
	
	/**
	 *	初期設定
	 */
	function init(){
		var userAgent = window.navigator.userAgent.toLowerCase();
		var appVersion = window.navigator.appVersion.toLowerCase();
		//古いIEかどうか
		if(userAgent.indexOf('msie') != -1 && (appVersion.indexOf('msie 8.') != -1 || appVersion.indexOf('msie 7.') != -1)){
			isOldIE = true;
		}
		//PS3ブラウザかどうか
		if(userAgent.indexOf('playstation 3') != -1){
			isPS3 = true;
		}
		//PSVitaブラウザかどうか
		if(userAgent.indexOf('playstation vita') != -1){
			isVita = true;
		}
		//ウィンドウリサイズ設定
		if(!isOldIE){
			$(window).resize(windowResize).resize();
		}else{
			mode = MODE.PC;
		}
		//ヘッダーアンカー設定
		setAnchor();
		//ウィンドウスクロール設定
		$(window).scroll(windowScroll).scroll();
		//jsonファイル読み込み
		loadJson();
	}
	
	/**
	 *	ヘッダーアンカー設定
	 */
	function setAnchor(){
		var $anchor = $('#top-anchor');
		//PSVitaブラウザの場合非表示
		if(isVita){
			$anchor.css('display','none');
			return false;
		}
		$anchor.css({
			'top':-$anchor.outerHeight(),
			'visibility':'visible'
		});
		$('#anchor-nav a').click(function(e){
			var pos = Math.ceil($($(this).attr('href')).offset().top);
			$('html,body').animate({
				'scrollTop':(pos - $anchor.outerHeight() >= 0) ? pos - $anchor.outerHeight() : 0
			},{
				duration:1000,
				easing:'easeOutQuint'
			});
			return false;
		});
	}
	
	/**
	 *	jsonファイル読み込み
	 */
	function loadJson(){
		var date = new Date();
		$.ajax({
			type:'GET',
			url:JSON_PATH + '?prm=' + date.getTime(),
			dataType:'json',
			success:loadJsonComplete,
			error:function(e){
			}
		});
	}
	
	/**
	 *	jsonファイル読み込み完了
	 */
	function loadJsonComplete(json){
		
		jsonObj = json[0];
		
		/*--------------------
		NEW
		--------------------*/
		//左
		if(jsonObj.news.left){
			var $li = $(document.createElement('li')).addClass('left');
			var $new = $(document.createElement('div')).addClass('new');
			var $innr = $(document.createElement('div')).addClass('new-inner');
			var $a = $(document.createElement('a')).attr({
				'href':jsonObj.news.left.href,
				'target':jsonObj.news.left.target
			}).addClass('clearfix');
			if(jsonObj.news.left.type == 'movie'){
				$a.addClass(JS_MOVIE_BTN);
			}
			var $left = $(document.createElement('div')).addClass('left');
			var $img = $(document.createElement('img')).attr({
				'src':jsonObj.news.left.src,
				'alt':jsonObj.news.left.alt,
				'width':'100%'
			}).removeAttr('height');
			var $right = $(document.createElement('div')).addClass('right');
			var $h4 = $(document.createElement('h4')).html(jsonObj.news.left.title);
			var $p = $(document.createElement('p')).html(jsonObj.news.left.txt);
			$('#title-inner .js-load-new').append($li.append($new.append($innr.append($a.append($left.append($img)).append($right.append($h4).append($p))))));
		}
		//右
		if(jsonObj.news.right){
			var $li = $(document.createElement('li')).addClass('right');
			var $new = $(document.createElement('div')).addClass('new');
			var $innr = $(document.createElement('div')).addClass('new-inner');
			var $a = $(document.createElement('a')).attr({
				'href':jsonObj.news.right.href,
				'target':jsonObj.news.right.target
			}).addClass('clearfix');
			if(jsonObj.news.right.type == 'movie'){
				$a.addClass(JS_MOVIE_BTN);
			}
			var $left = $(document.createElement('div')).addClass('left');
			var $img = $(document.createElement('img')).attr({
				'src':jsonObj.news.right.src,
				'alt':jsonObj.news.right.alt,
				'width':'100%'
			}).removeAttr('height');
			var $right = $(document.createElement('div')).addClass('right');
			var $h4 = $(document.createElement('h4')).html(jsonObj.news.right.title);
			var $p = $(document.createElement('p')).html(jsonObj.news.right.txt);
			$('#title-inner .js-load-new').append($li.append($new.append($innr.append($a.append($left.append($img)).append($right.append($h4).append($p))))));
		}
		
		/*--------------------
		トピックス(large)
		--------------------*/
		$(jsonObj.topics.large).each(function(index,element){
			var $bnr = $(document.createElement('div')).addClass('bnr');
			var $a = $(document.createElement('a')).attr({
				'href':element.href,
				'target':element.target
			});
			var $img = $(document.createElement('img')).attr({
				'src':element.src,
				'alt':element.alt,
				'width':'100%'
			}).removeAttr('height');
			$('#topics .js-load-large').append($bnr.append($a.append($img)));
		});
		
		/*--------------------
		トピックス(middle)
		--------------------*/
		var topicsMiddleCount = 0;
		$(jsonObj.topics.middle).each(function(index,element){
			var $li = $(document.createElement('li'));
			var $wrap = $(document.createElement('div')).addClass('wrap');
			var $a = $(document.createElement('a')).attr({
				'href':element.href,
				'target':element.target
			});
			if(element.type == 'movie'){
				$a.addClass(JS_MOVIE_BTN);
			}
			var $pImg = $(document.createElement('p')).addClass('img');
			var $img = $(document.createElement('img')).attr({
				'src':element.src,
				'alt':element.alt,
				'width':'100%'
			}).removeAttr('height');
			try{
				$img.imagesLoaded(function(){
					topicsMiddleCount = checkImagesLoaded(topicsMiddleCount,$(jsonObj.topics.middle).length);
				});
			}catch(e){
			}
			var $txt = $(document.createElement('p')).addClass('txt').html(element.txt);
			$('#topics .js-load-middle').append($li.append($wrap.append($a.append($pImg.append($img)).append($txt))));
		});
		//空要素生成
		var length = ($(jsonObj.topics.middle).length % 3 == 0) ? 0 : 3 - ($(jsonObj.topics.middle).length % 3);
		for(var i = 0;i < length;i++){
			$('#topics .js-load-middle').append($(document.createElement('li')).append($(document.createElement('div')).addClass('wrap sp_none').html('&nbsp;')));
		}
		
		/*--------------------
		ピックアップ
		--------------------*/
		var $bg = $(document.createElement('img')).addClass('bg').attr({
			'src':jsonObj.picup.bg.src,
			'alt':jsonObj.picup.bg.alt,
			'width':'100%'
		}).removeAttr('height');
		$('#picup .js-load-bg').append($bg);
		var $h4 = $(document.createElement('h4')).html(jsonObj.picup.txt.title);
		var $p = $(document.createElement('p')).html(jsonObj.picup.txt.txt);
		$('#picup .js-load-txt').append($h4).append($p);
		var $img = $(document.createElement('img')).attr({
			'src':jsonObj.picup.movie.src,
			'alt':jsonObj.picup.movie.alt,
			'width':'100%'
		}).removeAttr('height');
		if(jsonObj.picup.movie.type == 'movie'){
			var $a = $(document.createElement('a')).attr({
				'href':jsonObj.picup.movie.href,
				'target':jsonObj.picup.movie.target
			}).addClass(JS_MOVIE_BTN).append($img);
		}
		$('#picup .js-load-movie').append((jsonObj.picup.movie.type == 'movie') ? $a : $img);
		var picupNavCount = 0;
		$(jsonObj.picup.nav).each(function(index,element){
			var $li = $(document.createElement('li'));
			var $a = $(document.createElement('a')).attr({
				'href':element.href,
				'target':element.target
			});
			var $pImg = $(document.createElement('p')).addClass('img');
			var $img = $(document.createElement('img')).attr({
				'src':element.src,
				'alt':element.alt,
				'width':'100%'
			}).removeAttr('height');
			try{
				$img.imagesLoaded(function(){
					picupNavCount = checkImagesLoaded(picupNavCount,$(jsonObj.picup.nav).length);
				});
			}catch(e){
			}
			var $span = $(document.createElement('span')).html(element.subtitle);
			var $h4 = $(document.createElement('h4')).html(element.title).append($span);
			$('#picup .js-load-nav').append($li.append($a.append($pImg.append($img)).append($h4)));
		});
		//空要素生成
		setBlankPanel();
		
		/*--------------------
		ゲームソフト(large)
		--------------------*/
		$(jsonObj.game.large).each(function(index,element){
			var $bnr = $(document.createElement('div')).addClass('bnr');
			var $a = $(document.createElement('a')).attr({
				'href':element.href,
				'target':element.target
			});
			var $img = $(document.createElement('img')).attr({
				'src':element.src,
				'alt':element.alt,
				'width':'100%'
			}).removeAttr('height');
			$('#game .js-load-large').append($bnr.append($a.append($img)));
		});
		
		/*--------------------
		ゲームソフト(middle)
		--------------------*/
		var gameMiddleCount = 0;
		$(jsonObj.game.middle).each(function(index,element){
			var $li = $(document.createElement('li'));
			var $wrap = $(document.createElement('div')).addClass('wrap');
			var $a = $(document.createElement('a')).attr({
				'href':element.href,
				'target':element.target
			});
			if(element.type == 'movie'){
				$a.addClass(JS_MOVIE_BTN);
			}
			var $pImg = $(document.createElement('p')).addClass('img');
			var $img = $(document.createElement('img')).attr({
				'src':element.src,
				'alt':element.alt,
				'width':'100%'
			}).removeAttr('height');
			try{
				$img.imagesLoaded(function(){
					gameMiddleCount = checkImagesLoaded(gameMiddleCount,$(jsonObj.game.middle).length);
				});
			}catch(e){
			}
			var $txt = $(document.createElement('p')).addClass('txt').html(element.txt);
			$('#game .js-load-middle').append($li.append($wrap.append($a.append($pImg.append($img)).append($txt))));
		});
		//空要素生成
		var length = ($(jsonObj.game.middle).length % 3 == 0) ? 0 : 3 - ($(jsonObj.game.middle).length % 3);
		for(var i = 0;i < length;i++){
			$('#game .js-load-middle').append($(document.createElement('li')).append($(document.createElement('div')).addClass('wrap sp_none').html('&nbsp;')));
		}
		
		/*--------------------
		動画ボタン設定
		--------------------*/
		setMovieBtn();
		
		/*--------------------
		古いIEの場合
		--------------------*/
		if(isOldIE){
			$.getScript(SELECTIVIZR_PATH);
		}
		
	}
	
	/**
	 *	動画ボタン設定
	 */
	function setMovieBtn(){
		
		//NEW用
		$('#title-inner .js-load-new .' + JS_MOVIE_BTN).each(function(index,element){
			setMovieArea($(this),$(this).parent().parent().parent());
		});
		
		//ピックアップ用
		$('#picup .js-load-movie .' + JS_MOVIE_BTN).each(function(index,element){
			setMovieArea($(this),$('#picup-info'));
		});
		
		//3カラム用
		$('.list-3col .' + JS_MOVIE_BTN).each(function(index,element){
			setMovieArea($(this),$(this).parent().parent());
		});
		
		function setMovieArea($btn,$appendTarget){
			
			var $wrap = $(document.createElement('div')).addClass(JS_MOVIE_WRAPPER);
			var $cont = $(document.createElement('div')).addClass(JS_MOVIE_CONTENTS);
			var $innr = $(document.createElement('div')).addClass(JS_MOVIE_CONTENTS_INNR);
			var $close = $(document.createElement('p')).addClass(JS_MOVIE_CLOSE);
			var $iframe = $(document.createElement('iframe')).attr({
				'frameborder':'0',
				'width':'560',
				'height':'315'
			});
			var sID;
			$appendTarget.append($wrap.append($cont.append($innr.append($iframe)).append($close)));
			
			$btn.click(movieOpen);
			$close.click(movieClose);
			
			function movieOpen(e){
				if(!$btn.isOpen){
					$btn.isOpen = true;
					var $ul = $appendTarget.parent('ul');
					$ul.children('li:not(:eq(' + $ul.children('li').index($appendTarget) + '))').find('.js-movie-close').click();
					$wrap.addClass('open');
					setTimeout(function(){
						$wrap.stop().animate({
							'height':$cont.innerHeight()
						},{
							duration:250
						});
						var $anchor = $('#top-anchor');
						clearTimeout(sID);
						sID = setTimeout(function(){
							$('html,body').stop().animate({
								'scrollTop':($anchor.css('display') != 'none') ? $wrap.offset().top - $anchor.outerHeight() : $wrap.offset().top
							},{
								duration:500,
								easing:'easeOutQuint',
								complete:function(){
									$iframe.attr({
										'src':$btn.attr('href')
									});
									$wrap.css({
										'height':'100%'
									});
								}
							});
						},250);
					},50);
				}else{
					$close.click();
				}
				return false;
			}
			
			function movieClose(e){
				$iframe.attr({
					'src':''
				});
				$wrap.addClass('close').css({
					'height':$cont.innerHeight()
				}).stop().animate({
					'height':0
				},{
					duration:250,
					complete:function(){
						$wrap.removeClass('open').removeClass('close');
					}
				});
				if($btn.isOpen){
					var $anchor = $('#top-anchor');
					$('html,body').stop().animate({
						'scrollTop':($anchor.css('display') != 'none') ? $btn.offset().top - $anchor.outerHeight() - 100 : $btn.offset().top - 100
					},{
						duration:500,
						easing:'easeOutQuint'
					});
				}
				$btn.isOpen = false;
				return false;
			}
			
		}
		
	}
	
	/**
	 *	画像読み込み完了時にタイリング
	 */
	function checkImagesLoaded(count,length){
		if(++count >= length && mode != MODE.SP){
			//tile.js設定
			setTile();
		}
		return count;
	}
	
	/**
	 *	空要素生成(5カラム⇔4カラム変動用)
	 */
	function setBlankPanel(){
		
		$('#menu-list .js-nav .sp_none').remove();
		$('#picup .js-load-nav .sp_none').remove();
		
		if(mode == MODE.PC){ //5カラム
			
			var length = 0;
			/*--------------------
			メニュー
			--------------------*/
			length = ($('#menu-list .js-nav li').length % 5 == 0) ? 0 : 5 - ($('#menu-list .js-nav li').length % 5);
			for(var i = 0;i < length;i++){
				$('#menu-list .js-nav').append($(document.createElement('li')).addClass('sp_none').html('&nbsp;'));
			}
			
			/*--------------------
			ピックアップ
			--------------------*/
			try{
				length = ($(jsonObj.picup.nav).length % 5 == 0) ? 0 : 5 - ($(jsonObj.picup.nav).length % 5);
				for(var i = 0;i < length;i++){
					$('#picup .js-load-nav').append($(document.createElement('li')).addClass('sp_none').html('&nbsp;'));
				}
			}catch(e){
			}
			
		}else if(mode == MODE.TAB){ //4カラム
			
			var length = 0;
			/*--------------------
			メニュー
			--------------------*/
			length = ($('#menu-list .js-nav li').length % 4 == 0) ? 0 : 4 - ($('#menu-list .js-nav li').length % 4);
			for(var i = 0;i < length;i++){
				$('#menu-list .js-nav').append($(document.createElement('li')).addClass('sp_none').html('&nbsp;'));
			}
		
			/*--------------------
			ピックアップ
			--------------------*/
			try{
				length = ($(jsonObj.picup.nav).length % 4 == 0) ? 0 : 4 - ($(jsonObj.picup.nav).length % 4);
				for(var i = 0;i < length;i++){
					$('#picup .js-load-nav').append($(document.createElement('li')).addClass('sp_none').html('&nbsp;'));
				}
			}catch(e){
			}
		
		}
		
	}
	
	/**
	 *	ウィンドウリサイズ
	 *	IE8以下の場合は設定しない
	 */
	function windowResize(e){
		var windowW = (window.innerWidth) ? window.innerWidth : 0;
		if(WIDTH[MODE.PC] < windowW && mode != MODE.PC){ //PC表示に切り替わった場合
			mode = MODE.PC;
			//空要素生成
			setBlankPanel();
		}else if(WIDTH[MODE.TAB] <= windowW && windowW <= WIDTH[MODE.PC] && mode != MODE.TAB){ //タブレット表示に切り替わった場合
			mode = MODE.TAB;
			//空要素生成
			setBlankPanel();
		}else if(windowW < WIDTH[MODE.TAB] && mode != MODE.SP){ //スマホ表示に切り替わった場合
			mode = MODE.SP;
			removeTile();
		}
		if(mode != MODE.SP){
			setTile();
		}
	}
	
	/**
	 *	ウィンドウスクロール
	 */
	function windowScroll(e){
		//var $header = $('#header');
		//var $header = ($('#header') != undefined ) ? $('#header') : $('#global-header');
		var $header = $('#global-header');
		var pos = $header.offset().top + $header.height();
		var $anchor = $('#top-anchor');
		var $window = $(this);
		if($window.scrollTop() > pos && !isAnchor){
			if(!isPS3){
				$anchor.stop().animate({
					'top':0
				},250);
			}else{
				$anchor.css('top',0);
			}
			isAnchor = true;
		}else if($window.scrollTop() <= pos && isAnchor){
			if(!isPS3){
				$anchor.stop().animate({
					'top':-$anchor.outerHeight()
				},250);
			}else{
				$anchor.css('top',-$anchor.outerHeight());
			}
			isAnchor = false;
		}
		
		
		$('#anchor-nav a').each(function(index,element){
//			var $this = $(this);
//			var $target = $($this.attr('href'));
//			var top = Math.ceil($target.offset().top) - Math.floor($anchor.outerHeight());
			var $this = $(this);
			var $target = $($this.attr('href'));
var top = Math.ceil($this.offset().top) - Math.floor($anchor.outerHeight());
			var bottom = Math.floor($target.offset().top) + Math.floor($target.innerHeight());
			var scrollTop = Math.ceil($window.scrollTop());
			if(top <= scrollTop && scrollTop < bottom){
				if(!$this.parent().hasClass('right')){
					$('#anchor-nav a').removeClass('current');
					$this.addClass('current');
				}
			}else{
				if(!$this.parent().hasClass('right')){
					$this.removeClass('current');
				}
			}
			if(top <= scrollTop){
				if(!$this.parent().hasClass('right')){
					$this.addClass('up');
				}
			}else{
				if(!$this.parent().hasClass('right')){
					$this.removeClass('up');
				}
			}
		});
		
	}
	
	/**
	 *	tile.js設定
	 */
	function setTile(){
		$(HEIGHT_LINE_TARGET).each(function(index,element){
			try{
				$(element).tile();
			}catch(e){
			}
		});
	}
	
	/**
	 *	tile.js削除
	 */
	function removeTile(){
		$(HEIGHT_LINE_TARGET).each(function(index,element){
			$(element).css('height','');
		});
	}
	
});
