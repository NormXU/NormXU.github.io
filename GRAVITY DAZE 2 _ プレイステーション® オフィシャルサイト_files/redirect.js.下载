var path = window.location.pathname;

var ua = navigator.userAgent;
var isSP = false;
if (ua.indexOf("iPhone") != -1) isSP = true;
if (ua.indexOf("iPod") != -1) isSP = true;
if ((ua.indexOf("Android") != -1) && (ua.indexOf("Mobile") != -1)) {
if (ua.indexOf('A1_07') > 0 || ua.indexOf('SC-01C') > 0) {
  //tablet
  } else {
  isSP = true;
  }
}
var sc=(location.search);
var hs=(location.hash);

if(path.indexOf("/sp/") != -1){
  if(!isSP){
    window.location.href = "../"+(sc)+(hs);
  }
}else{
  if(isSP) {
    window.location.href = "./sp/"+(sc)+(hs);
  }
}

